{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "files": {
    "includes": [
      "**/*.js",
      "**/*.mjs",
      "**/*.ts",
      "**/*.json",
      "!node_modules",
      "!dist",
      "!coverage",
      "!.git",
      "!.claude",
      "!pnpm-lock.yaml"
    ]
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "complexity": {
        "useOptionalChain": "off"
      },
      "suspicious": {
        "noPrototypeBuiltins": "off"
      }
    }
  }
}
